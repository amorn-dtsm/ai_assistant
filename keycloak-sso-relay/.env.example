# Port the relay listens on
PORT=3002

###########################################
######## Keycloak (OIDC provider) #########
###########################################
# Realm issuer URL. Must be reachable by BOTH the relay container and the
# user's browser under the SAME hostname (the issuer inside tokens must match).
# Docker Desktop (Win/Mac): host.docker.internal works for both.
# Linux: add "127.0.0.1 host.docker.internal" to /etc/hosts, or use a real DNS name.
KEYCLOAK_ISSUER=http://host.docker.internal:8080/realms/anythingllm

# Confidential client registered in the realm (Client authentication: ON).
KEYCLOAK_CLIENT_ID=anythingllm-relay
KEYCLOAK_CLIENT_SECRET=change-me

# Keycloak role names mapped to AnythingLLM roles. A user with none of these
# roles gets the "default" role. Checked against realm roles AND client roles.
KEYCLOAK_ROLE_ADMIN=anythingllm-admin
KEYCLOAK_ROLE_MANAGER=anythingllm-manager

###########################################
######## Relay + AnythingLLM URLs #########
###########################################
# Browser-facing base URL of this relay (used to build the OIDC redirect URI:
# {RELAY_PUBLIC_URL}/oidc/callback - register that exact URI in Keycloak).
RELAY_PUBLIC_URL=http://localhost:3002

# Server-to-server base URL of AnythingLLM (from inside docker-compose this
# is the service name; when running the relay on the host use localhost).
ANYTHINGLLM_API_URL=http://anything-llm:3001

# Browser-facing base URL of AnythingLLM (where users get redirected after login).
ANYTHINGLLM_PUBLIC_URL=http://localhost:3001

# Developer API key generated in AnythingLLM (Settings > Tools > Developer API).
# Use a dedicated key for the relay so it can be revoked independently.
ANYTHINGLLM_API_KEY=change-me

###########################################
######## Provisioning behavior ############
###########################################
# Create AnythingLLM users automatically on first Keycloak login.
JIT_PROVISIONING=true

# Re-apply the Keycloak-derived role to the AnythingLLM user on every login.
ROLE_SYNC=true
